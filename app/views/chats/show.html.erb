<% has_messages = @chat.messages.any? %>
<div class="container">

  <div class="messages mt-4">
    <% @chat.messages.each do |message| %>

    <%# Print the message of the user %>
      <% if message.role == "user" %>
        <div class="d-flex justify-content-end mb-3 text-dark">
          <div class="px-3 pb-0 pt-3 rounded-pill" style="background: linear-gradient(135deg, #0092B4, #06958C); color: white;">
            <%= raw(render_markdown(message.content)) %>
          </div>
        </div>

    <%# Print the response of the assistant if it is the exercises %>
      <% elsif message.role == "assistant" %>
        <% begin %>
          <% hash = JSON.parse(message.content) %>
          <div class="d-flex justify-content-start mb-3 text-dark align-items-center" style="max-width: 80%;">
            <div class="px-4 pb-4 pt-4 d-flex">
              <% exercice = @chat.exercices.find_by!(name: hash["name"]) %>
              <div class="d-flex">
                <div>
                  <iframe
                    src="<%= hash["video_url"].gsub("watch?v=", "embed/") %>"
                    frameborder="0"
                    allowfullscreen>
                  </iframe>
                </div>
                <div>
                  <h5><%= hash["name"] %></h5>
                  <span>Description : <%= hash["description"] %></span><br>
                  <span>Objective : <%= hash["objective"] %></span><br>
                  <span>Repetitions : <%= hash["rep_amount"] %></span>
                </div>

        <%# Dropdown button to add to a routine %>
                <div>
                  <div class="dropdown ms-auto">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle rounded-pill" type="button" data-bs-toggle="dropdown">
                      + Add to a routine
                    </button>
                    <ul class="dropdown-menu">
                      <% current_user.routines.each do |routine| %>
                        <li>
                          <%= link_to routine.name, add_to_routine_exercise_path(exercice, routine_id: routine.id),
                              method: :patch,
                              data: { turbo_method: :patch },
                              class: "dropdown-item" %>
                        </li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>

    <%# Print the messages of the assistant if they aren't the exercises %>
        <% rescue JSON::ParserError %>
          <div class="d-flex justify-content-start mb-3">
            <div class="px-3 py-3 rounded-4 text-dark" style="max-width: 90%">
              <%= simple_format(message.content) %>
            </div>
          </div>
        <% end %>

      <% end %> <%# closes if/elsif %>
    <% end %> <%# closes messages.each %>
  </div> <%# closes id="messages" %>

  <div>
  <div id="new_message_container" class="<%= has_messages ? 'sticky-bottom' : 'centered-input' %>">
    <%= simple_form_for [@chat, @message] do |f| %>
      <div class="d-flex <%= has_messages ? 'flex-row align-items-center gap-2' : 'flex-column align-items-center gap-3' %>">
        <%= f.input :content, label: false, required: true, placeholder: "What do you want to do?", input_html: { class: "rounded-pill" }, wrapper_html: { class: "mb-0 flex-grow-1 w-100" } %>
        <%= f.button :submit, 'Ask SharkTrainer', class: "btn-custom-secondary text-nowrap mb-3 rounded-pill" %>
      </div>
    <% end %>
  </div>
  </div>
</div>
