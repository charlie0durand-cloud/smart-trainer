<% content_for :sidebar do %>
  <%= render "shared/sidebar" %>
<% end %>
<div class="container">
  <div id="messages">
    <% @chat.messages.each do |message| %>
      <% if message.role == "user" %>
        <div class="d-flex justify-content-end mb-3 text-dark">
          <div class="bg-white px-3 pb-0 pt-3 rounded-4">
            <%= raw(render_markdown(message.content)) %>
          </div>
        </div>
      <% elsif message.role == "assistant" %>
        <div class="d-flex justify-content-start mb-3 bg-light rounded-4 text-dark align-items-center" style="max-width: 80%">
          <div class="px-4 pb-4 pt-4 d-flex">
            <% string = message.content %>
            <% hash = eval(string) %>
              <div class="d-flex">
                <div>
                  <iframe
                    src="<%= hash[:video_url].gsub("watch?v=", "embed/") %>"
                    frameborder="0"
                    allowfullscreen>
                  </iframe>
                </div>
                <div>
                  <h5><%= hash[:name] %></h5>
                  <span>Description : <%= hash[:description] %></span><br>
                  <span>Objective : <%= hash[:objective] %></span><br>
                  <span>Repetitions : <%= hash[:rep_amount] %></span>
                </div>

<%# Dropdown button to add an exercice to a routine %>
                  <div>
                    <div class="dropdown ms-auto">
                      <button class="btn btn-sm btn-outline-secondary dropdown-toggle rounded-4" type="button" data-bs-toggle="dropdown">
                        + Add to a routine
                      </button>
                      <ul class="dropdown-menu">
                        <% current_user.routines.each do |routine| %>
                          <li>
                            <%= link_to routine.name, add_to_routine_exercise_path(message, routine_id: routine.id),
                                method: :patch,
                                data: { turbo_method: :patch },
                                class: "dropdown-item" %>
                          </li>
                        <% end %>
                      </ul>
                    </div>
                  </div>

          </div>
        </div>
      </div>
      <% end %>
    <% end %>

  <div id="new_message_container">
    <%= simple_form_for [@chat, @message] do |f| %>
        <%= f.input :content, label: "Ask a question", required: true, placeholder: "What exercises target the hamstrings?", class:"dialog-bar" %>
        <%= f.button :submit, 'Ask LLM', class: 'btn-custom-primary m-2' %>
    <% end %>
  </div>
</div>
</div>
