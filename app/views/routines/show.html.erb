<div class="routine-header">
  <div class="back-button">
    <%= link_to "<<Back", chat_path(Chat.last), class: "btn-back" %>
  </div>
  <h1><%= @routine.name.capitalize %></h1>
  <div class="delete-button">
    <%= link_to routine_path(@routine), data: { turbo_method: :delete }, class: "btn-delete" do %>
      Delete routine
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
        <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
        <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
      </svg>
    <% end %>
  </div>
</div>

<% @exercices.each do |exercice| %>
<% imagerand = ["christophe19.png", "miniature-2.png", "miniature-3.png", "christophe117.png"].sample %>
  <div class="cards">
    <%= button_to remove_from_routine_exercise_path(exercice), method: :patch, class: "btn-delete-card" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
        <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
        <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
      </svg>
    <% end %>
    <div class="video">
    <%= image_tag imagerand, alt: exercice.name %>
    </div>
    <div class="exercise-info">
      <p><strong>🚀<%= exercice.name %></strong></p>
      <p><%= exercice.description %></p>
      <p><strong>Répétitions :</strong> <%= exercice.rep_amount %></p>
      <p><strong>Objectif :</strong> <%= exercice.objective %></p>
    </div>
  </div>
<% end %>
