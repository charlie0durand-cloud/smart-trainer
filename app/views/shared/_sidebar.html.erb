<aside class="sidebar" id="sidebar" data-state="expanded">

  <div class="sidebar-inner">

    <div>
      <%= link_to new_routine_path, class: "btn-new-routine" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="M12 5v14"/>
        </svg>
        <span>Nouvelle routine</span>
      <% end %>
    </div>

    <nav>
      <ul>
        <% @routines.each do |routine| %>
          <li class="sidebar-menu-item card-index-routine">
            <%= link_to routine.name, routine_path(routine) %>
            <%= button_to routine_path(routine), method: :delete, class: "sidebar-delete", data: { turbo_confirm: "Supprimer cette routine ?" } do %>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 6 5 6 21 6"/>
                <path d="M19 6l-1 14H6L5 6"/>
                <path d="M10 11v6"/><path d="M14 11v6"/>
                <path d="M9 6V4h6v2"/>
              </svg>
            <% end %>
          </li>
        <% end %>
      </ul>
    </nav>

  </div>
</aside>
