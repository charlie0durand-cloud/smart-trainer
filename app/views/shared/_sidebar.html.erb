<ul class="nav" data-toggle-target="hideable">
  <%= link_to new_routine_path, class: "btn-new-routine nav-item" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
      fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12h14"/><path d="M12 5v14"/>
    </svg>
    <span class="sidebar-text">New routine</span>
  <% end %>
  <% @routines.each do |routine| %>
    <li class="nav-item card-index-routine">
        <div>
          <%= link_to routine.name, routine_path(routine) %>
        </div>
        <div class="sidebar-text">
          <%= link_to routine_path(routine), data: { turbo_method: :delete, turbo_confirm: "Supprimer cette routine ?" } do %>
            <i class="fa-solid fa-trash"></i>
          <% end %>
        </div>
    </li>
  <% end %>

  <div class="icons mt-2 px-4">
    <%= render "shared/sidebar_icons" %>
  </div>
</ul>
